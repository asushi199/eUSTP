# === Pangkalan data (Supabase Postgres) ===
# Runtime (Vercel): guna Transaction Pooler URL (port 6543)
# Migrasi tempatan: guna Direct connection URL (port 5432)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# === Auth.js ===
# Jana dengan: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# === Seed ===
SEED_ADMIN_PASSWORD=

# === Gambar laporan (GAS Web App -> Google Drive) — Fasa C ===
GAS_WEB_APP_URL=
GAS_UPLOAD_SECRET=

# === Tempahan (token kelulusan + gambar bilik) — Fasa D ===
APP_BASE_URL=http://localhost:3000
ADMIN_SESSION_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=room-photos
